{
  "version": "0.2.0",
  "configurations": [
    
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Integration Test",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "--inspect"],
      "args": ["src/__tests__/integration.test.ts"],
      "cwd": "${workspaceFolder}/vertex-orm",
      "sourceMaps": true,
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
